{
  "title": "VPS & StreamVision Overview",
  "timezone": "browser",
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Total Traefik Gateway Requests",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(traefik_entrypoint_requests_total)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Backend Connectivity Errors (5xx)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(traefik_service_requests_total{code=~\"5..\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "logs",
      "title": "Docker System Logs (StreamVision + Others)",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "{container=~\".+\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 38
}
