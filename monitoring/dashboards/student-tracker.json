{
  "title": "Student Tracker — App Logs & Health",
  "description": "Live logs, HTTP error rates, request traffic and container health for the student-tracker service",
  "uid": "student-tracker-v3",
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "tags": ["student-tracker", "school", "loki"],

  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "📊 At a Glance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Total Log Lines (Last 1h)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".*student-tracker.*\"}[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short"
        }
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Error Lines (4xx / 5xx)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".*student-tracker.*\"} |~ \" [45][0-9]{2} \" [1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10, "color": "orange" },
              { "value": 50, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Warn / Error Log Events",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".*student-tracker.*\"} |~ \"(?i)(error|warn|exception|fail)\" [1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "orange" },
              { "value": 20, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "VPS CPU %",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "orange" },
              { "value": 90, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 6,
      "type": "stat",
      "title": "VPS Memory Used %",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - ((node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 75, "color": "orange" },
              { "value": 90, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Traefik Req/s (edu routes)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traefik_service_requests_total{service=~\"edu.*\"}[1m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "continuous-BlPu" } }
      }
    },

    {
      "id": 10,
      "type": "row",
      "title": "🌐 HTTP Traffic via Traefik",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Request Rate by Status Code",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traefik_service_requests_total{service=~\"edu.*\", code=~\"2..\"}[1m]))",
          "refId": "A",
          "legendFormat": "2xx Success"
        },
        {
          "expr": "sum(rate(traefik_service_requests_total{service=~\"edu.*\", code=~\"3..\"}[1m]))",
          "refId": "B",
          "legendFormat": "3xx Redirect"
        },
        {
          "expr": "sum(rate(traefik_service_requests_total{service=~\"edu.*\", code=~\"4..\"}[1m]))",
          "refId": "C",
          "legendFormat": "4xx Client Error"
        },
        {
          "expr": "sum(rate(traefik_service_requests_total{service=~\"edu.*\", code=~\"5..\"}[1m]))",
          "refId": "D",
          "legendFormat": "5xx Server Error"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 12, "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx Success" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#37872D", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "4xx Client Error" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#FF7383", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "5xx Server Error" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#C4162A", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Request Latency: p99 & p50",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(traefik_service_request_duration_seconds_bucket{service=~\"edu.*\"}[5m])) by (le))",
          "refId": "A",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(traefik_service_request_duration_seconds_bucket{service=~\"edu.*\"}[5m])) by (le))",
          "refId": "B",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "📋 Live Log Streams",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "Log Volume by Level (lines / min)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({container=~\".*student-tracker.*\"} |~ \"(?i)(error|exception|fatal|fail)\" [1m]))",
          "refId": "A",
          "legendFormat": "Errors"
        },
        {
          "expr": "sum(rate({container=~\".*student-tracker.*\"} |~ \"(?i)warn\" [1m]))",
          "refId": "B",
          "legendFormat": "Warnings"
        },
        {
          "expr": "sum(rate({container=~\".*student-tracker.*\"} |~ \"GET |POST |PUT |DELETE |PATCH \" [1m]))",
          "refId": "C",
          "legendFormat": "HTTP Requests"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15, "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#C4162A", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Warnings" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#FA6400", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "HTTP Requests" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#5794F2", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 22,
      "type": "logs",
      "title": "🔴 Errors & Exceptions",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*student-tracker.*\"} |~ \"(?i)(error|exception|fatal|fail|uncaught|ER_|ECONNREFUSED)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },

    {
      "id": 23,
      "type": "logs",
      "title": "🟡 Warnings",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*student-tracker.*\"} |~ \"(?i)(warn|deprecated|timeout|slow)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },

    {
      "id": 24,
      "type": "logs",
      "title": "📥 All Logs — Real-time Stream",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 33 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{container=~\".*student-tracker.*\"}", "refId": "A" }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },

    {
      "id": 30,
      "type": "row",
      "title": "🛣️ Route Error Analysis",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },

    {
      "id": 31,
      "type": "logs",
      "title": "4xx Client Errors",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 50 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*student-tracker.*\"} |~ \" 4[0-9]{2} \"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },

    {
      "id": 32,
      "type": "logs",
      "title": "5xx Server Errors",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 50 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*student-tracker.*\"} |~ \" 5[0-9]{2} \"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },

    {
      "id": 40,
      "type": "row",
      "title": "🗄️ Database & Auth Events",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 60 },
      "collapsed": false
    },

    {
      "id": 41,
      "type": "logs",
      "title": "MySQL / DB Errors",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 61 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*student-tracker.*\"} |~ \"(?i)(mysql|sql|ER_|query error|pool|ECONNREFUSED)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },

    {
      "id": 42,
      "type": "logs",
      "title": "Auth Events (login / token / JWT)",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 61 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*student-tracker.*\"} |~ \"(?i)(login|logout|auth|token|jwt|session|INVALID_CREDENTIALS)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },

    {
      "id": 50,
      "type": "row",
      "title": "🐳 Container Lifecycle",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 71 },
      "collapsed": false
    },

    {
      "id": 51,
      "type": "logs",
      "title": "Startup / Shutdown / Crash Events",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 72 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*student-tracker.*\"} |~ \"(?i)(start|listen|shutdown|restart|SIGINT|SIGTERM|closing|pool|ready|running on)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ]
}
